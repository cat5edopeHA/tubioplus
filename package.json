{
  "name": "tubioplus",
  "version": "2.0.0",
  "description": "YouTube streaming addon for Stremio Lite",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test --config test/e2e/playwright.config.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "fastify": "^5.8.4",
    "pino": "^10.3.1",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
